# --- chain access (defaults are the official endpoints) ---
RPC_URL=https://rpc.botchain.ai
WSS_URL=wss://ws-rpc.botchain.ai

# --- signer (daemon + scripts only; restore needs NO key) ---
PRIVATE_KEY=0xYOUR_FUNDED_KEY_HERE

# --- registry (fill after: forge script script/Deploy.s.sol --broadcast) ---
REGISTRY_ADDRESS=0xDEPLOY_AND_RECORD
REGISTRY_DEPLOY_BLOCK=0

# --- indexing ---
DB_PATH=data/mirror.db
START_BLOCK=1066273
INDEX_USDT=1

# --- checkpoints (mode locked by hour-0 spike: blob | calldata) ---
CHECKPOINT_MODE=blob

# --- demo (printed by Deploy.s.sol; token recovery: npm run demo-pool -- --deploy-only) ---
DEMO_TOKEN_ADDRESS=0xDEPLOY_AND_RECORD
BEACON_READER_ADDRESS=0xDEPLOY_AND_RECORD

# --- api / web ---
API_PORT=3400
NEXT_PUBLIC_API_URL=http://localhost:3400
# server components under docker compose (compose overrides to http://daemon:3400)
API_URL_INTERNAL=http://localhost:3400
